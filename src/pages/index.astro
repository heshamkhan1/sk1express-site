                <p class="text-sm leading-relaxed mb-6 font-medium">Precision B2B logistics engineered for reliability. Operating out of Birmingham, servicing the entire UK mainland with dedicated vehicles.</p>
                <div class="flex items-center gap-2 text-white font-bold">
                    <span class="w-2 h-2 bg-green-500 rounded-full"></span> 24/7 Operations Active
                </div>
            </div>

            <!-- Links Column -->
            <div class="md:col-span-4">
                <h4 class="text-white font-bold uppercase tracking-wider mb-6 text-sm">Logistics Links</h4>
                <ul class="space-y-3 text-sm font-medium">
                    <li><a href="#solutions" class="hover:text-brand-accent transition-colors">Dedicated Solutions</a></li>
                    <li><a href="#industries" class="hover:text-brand-accent transition-colors">Industrial Sectors</a></li>
                    <li><a href="#fleet" class="hover:text-brand-accent transition-colors">Vehicle Specifications</a></li>
                    <li><a href="#faq" class="hover:text-brand-accent transition-colors">Operational FAQs</a></li>
                </ul>
            </div>

            <!-- Contact Column -->
            <div class="md:col-span-4 bg-slate-900 border border-slate-800 p-6 rounded-sm">
                <h4 class="text-white font-bold uppercase tracking-wider mb-4 text-sm">Direct Dispatch</h4>
                <ul class="space-y-4 text-sm font-medium">
                    <li>
                        <span class="block text-xs text-slate-500 mb-1 uppercase tracking-widest">Phone</span>
                        <a href="tel:+441210000000" class="text-white text-lg font-bold hover:text-brand-accent transition-colors">0121 000 0000</a>
                    </li>
