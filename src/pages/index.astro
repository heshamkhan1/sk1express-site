---
// Standalone landing page. No default Astro blog components imported to prevent CSS conflicts.
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SK1 Express | Dedicated Same Day Delivery UK</title>
    <meta name="description" content="Dedicated same-day courier service based in Manchester. Direct, B2B transport with no transhipments and complete control over time and route.">
    
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <style>
        html { scroll-behavior: smooth; }
        body { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    </style>
</head>
<body class="bg-slate-50 font-sans text-slate-900">

    <header class="w-full bg-white text-slate-900 py-5 px-6 md:px-12 flex justify-between items-center border-b border-slate-200 sticky top-0 z-50">
        <a href="/" class="text-2xl font-black tracking-tight hover:text-orange-600 transition">SK1<span class="text-orange-600">EXPRESS</span></a>
        <nav class="hidden md:flex gap-8 text-sm uppercase tracking-wider font-bold">
            <a href="#services" class="hover:text-orange-600 transition text-slate-600">Services</a>
            <a href="#fleet" class="hover:text-orange-600 transition text-slate-600">Our Fleet</a>
            <a href="#why-us" class="hover:text-orange-600 transition text-slate-600">Why Us</a>
        </nav>
        <a href="tel:+440000000000" class="bg-slate-900 hover:bg-slate-800 text-white px-6 py-2.5 font-bold uppercase text-sm tracking-wide transition">24/7 Dispatch</a>
    </header>

    <main>
        <section id="services" class="relative max-w-7xl mx-auto py-20 md:py-32 px-6">
            <div class="max-w-3xl">
                <span class="text-orange-600 uppercase tracking-widest font-extrabold text-sm mb-4 block">B2B Logistics Partner</span>
                <h1 class="text-5xl md:text-7xl font-black text-slate-900 mb-6 leading-tight tracking-tight">One vehicle.<br/>One job.<br/><span class="text-orange-600">Full responsibility.</span></h1>
                <p class="text-xl text-slate-600 mb-10 leading-relaxed font-medium">
                    We deliver dedicated, direct B2B transport with no transhipments and complete control over time and route. Your package travels in a vehicle assigned exclusively to your job. 
                </p>
                <div class="flex flex-wrap gap-4 mb-20">
                    <a href="#contact" class="bg-orange-600 hover:bg-orange-700 text-white px-8 py-4 font-bold text-lg transition uppercase tracking-wide">Get an Instant Quote</a>
                    <a href="#fleet" class="bg-white hover:bg-slate-50 text-slate-900 border border-slate-300 px-8 py-4 font-bold text-lg transition uppercase tracking-wide">View Fleet Capabilities</a>
                </div>
            </div>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 border-t border-slate-200 pt-16">
                <div class="bg-white border border-slate-200 p-8 shadow-sm">
                    <p class="text-4xl font-black text-orange-600 mb-2">60 Min</p>
                    <p class="text-slate-900 font-bold text-sm uppercase tracking-wider">Average Pickup Time</p>
                </div>
                <div class="bg-white border border-slate-200 p-8 shadow-sm">
                    <p class="text-4xl font-black text-slate-900 mb-2">99.8%</p>
                    <p class="text-slate-900 font-bold text-sm uppercase tracking-wider">On-Time Delivery</p>
                </div>
                <div class="bg-white border border-slate-200 p-8 shadow-sm">
                    <p class="text-4xl font-black text-slate-900 mb-2">24 / 7</p>
                    <p class="text-slate-900 font-bold text-sm uppercase tracking-wider">Service Availability</p>
                </div>
                <div class="bg-white border border-slate-200 p-8 shadow-sm">
                    <p class="text-4xl font-black text-orange-600 mb-2">100%</p>
                    <p class="text-slate-900 font-bold text-sm uppercase tracking-wider">UK Coverage</p>
                </div>
            </div>
        </section>

        <section id="fleet" class="bg-white border-y border-slate-200 py-24 px-6">
            <div class="max-w-7xl mx-auto">
                <div class="mb-16">
                    <span class="text-orange-600 uppercase tracking-widest font-extrabold text-sm block mb-2">Vehicles</span>
                    <h2 class="text-4xl font-black text-slate-900 tracking-tight">Dedicated Same Day Fleet</h2>
                </div>
                
                <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="bg-slate-50 p-8 border border-slate-200">
                        <h3 class="text-xl font-bold text-slate-900 mb-2">Small Van</h3>
                        <p class="text-slate-600 text-sm mb-6">Up to 450kg. Fast and agile for urban deliveries with easy parking access.</p>
                    </div>
                    <div class="bg-slate-50 p-8 border border-slate-200">
                        <h3 class="text-xl font-bold text-slate-900 mb-2">SWB Van</h3>
                        <p class="text-slate-600 text-sm mb-6">Up to 800kg. Versatile short wheel base van for medium loads.</p>
                    </div>
                    <div class="bg-slate-50 p-8 border border-slate-200">
                        <h3 class="text-xl font-bold text-slate-900 mb-2">LWB Van</h3>
                        <p class="text-slate-600 text-sm mb-6">Up to 1,000kg. Extended capacity for larger consignments.</p>
                    </div>
                    <div class="bg-slate-50 p-8 border border-slate-200">
                        <h3 class="text-xl font-bold text-slate-900 mb-2">Luton Van</h3>
                        <p class="text-slate-600 text-sm mb-6">Up to 1,000kg. High-volume capability with tail lift available.</p>
                    </div>
                </div>
            </div>
        </section>
        
        <section id="why-us" class="max-w-7xl mx-auto py-24 px-6">
            <div class="grid md:grid-cols-2 gap-16 items-center">
                <div>
                    <span class="text-orange-600 uppercase tracking-widest font-extrabold text-sm block mb-2">Direct Delivery</span>
                    <h2 class="text-4xl font-black text-slate-900 mb-6 tracking-tight">No hubs, no transfers, no delays.</h2>
                    <p class="text-slate-600 leading-relaxed mb-6 font-medium">
                        Your shipment travels alone in a vehicle assigned exclusively to your delivery. From your door to the destination without passing through depots or sorting centres. 
                    </p>
                </div>
                <div class="space-y-6">
                    <div class="bg-white border border-slate-200 p-8 shadow-sm">
                        <h4 class="font-bold text-slate-900 mb-2 text-lg">Real-Time GPS Tracking</h4>
                        <p class="text-slate-600 text-sm">Know exactly where your package is at all times. Live GPS tracking and instant updates.</p>
                    </div>
                    <div class="bg-white border border-slate-200 p-8 shadow-sm">
                        <h4 class="font-bold text-slate-900 mb-2 text-lg">Instant Proof of Delivery</h4>
                        <p class="text-slate-600 text-sm">Receive proof of delivery immediately after your shipment is delivered.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="contact" class="bg-slate-900 py-24 px-6">
            <div class="max-w-4xl mx-auto bg-white p-8 md:p-12 shadow-2xl">
                <h2 class="text-3xl font-black text-slate-900 mb-2 tracking-tight uppercase">Get an Instant Quote</h2>
                <p class="text-slate-600 mb-8 font-medium">For an immediate rate structure and vehicle allocation, enter your deployment details below.</p>
                
                <form class="space-y-6" id="quoteForm">
                    <div style="position: absolute; left: -5000px;" aria-hidden="true">
                        <input type="text" id="sk1_bot_trap" tabindex="-1" value="" autocomplete="off" />
                    </div>

                    <div class="grid md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs uppercase tracking-wider font-bold text-slate-600 mb-2">Collection Postcode</label>
                            <input type="text" id="collection" class="w-full bg-slate-50 border border-slate-300 p-4 font-bold text-slate-900 focus:outline-none focus:border-orange-600 transition" placeholder="e.g. M1 1AA" required maxlength="8" />
                            <p id="col-error" class="text-red-600 text-xs mt-1 hidden font-bold">Invalid UK Postcode</p>
                        </div>
                        <div>
                            <label class="block text-xs uppercase tracking-wider font-bold text-slate-600 mb-2">Delivery Postcode</label>
                            <input type="text" id="delivery" class="w-full bg-slate-50 border border-slate-300 p-4 font-bold text-slate-900 focus:outline-none focus:border-orange-600 transition" placeholder="e.g. EC1A 1BB" required maxlength="8" />
                            <p id="del-error" class="text-red-600 text-xs mt-1 hidden font-bold">Invalid UK Postcode</p>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs uppercase tracking-wider font-bold text-slate-600 mb-2">Cargo Description / Payload Weight</label>
                        <textarea id="cargo" class="w-full bg-slate-50 border border-slate-300 p-4 font-bold text-slate-900 focus:outline-none focus:border-orange-600 transition h-28" placeholder="e.g. 2 x Euro-pallets, industrial pump component, 450kg total" required></textarea>
                    </div>
                    <button type="submit" id="submitBtn" class="w-full bg-orange-600 hover:bg-orange-700 text-white font-bold py-4 transition text-lg uppercase tracking-wide">Submit Request for Pricing</button>
                </form>
            </div>
        </section>

        <script is:inline>
            const formatPostcode = (val) => {
                let v = val.toUpperCase().replace(/[^A-Z0-9]/g, '');
                if (v.length > 4) v = v.slice(0, -3) + ' ' + v.slice(-3);
                return v;
            };

            const isValidPostcode = (p) => /^[A-Z]{1,2}[0-9][A-Z0-9]? ?[0-9][A-Z]{2}$/i.test(p);

            ['collection', 'delivery'].forEach(id => {
                document.getElementById(id).addEventListener('input', (e) => {
                    e.target.value = formatPostcode(e.target.value);
                    document.getElementById(`${id.substring(0,3)}-error`).classList.add('hidden');
                });
            });

            document.getElementById('quoteForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const col = document.getElementById('collection').value;
                const del = document.getElementById('delivery').value;
                let hasError = false;

                if (!isValidPostcode(col)) { document.getElementById('col-error').classList.remove('hidden'); hasError = true; }
                if (!isValidPostcode(del)) { document.getElementById('del-error').classList.remove('hidden'); hasError = true; }
                if (hasError) return;

                const btn = document.getElementById('submitBtn');
                btn.disabled = true;
                btn.innerText = 'Transmitting...';

                const payload = {
                    collection: col,
                    delivery: del,
                    cargo: document.getElementById('cargo').value,
                    trap: document.getElementById('sk1_bot_trap').value
                };

                try {
                    const response = await fetch('https://api.sk1express.uk', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        alert('Transit request logged. Dispatch will contact you immediately.');
                        document.getElementById('quoteForm').reset();
                    } else {
                        alert('Routing error. Please call dispatch directly.');
                    }
                } catch (err) {
                    alert('Network error. Please call dispatch directly.');
                } finally {
                    btn.disabled = false;
                    btn.innerText = 'Submit Request for Pricing';
                }
            });
        </script>
    </main>

    <footer class="bg-white border-t border-slate-200 py-12 px-6 text-center text-xs tracking-wider text-slate-500 uppercase font-bold">
        <p>&copy; 2026 SK1 Express. All rights reserved. | Headquartered in Manchester.</p>
    </footer>
</body>
</html>
