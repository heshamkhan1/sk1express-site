                    <li><a href="#faq" class="hover:text-brand-accent transition-colors">Operational FAQs</a></li>
                </ul>
            </div>

            <!-- Contact Column -->
            <div class="md:col-span-4 lg:col-span-4">
                <h4 class="text-white font-bold uppercase tracking-wider mb-6 text-sm">Direct Dispatch</h4>
                <ul class="space-y-4 text-sm font-medium">
                    <li>
                        <span class="block text-xs text-gray-500 mb-1 uppercase tracking-widest">Phone</span>
