                        <span class="block text-xs text-slate-500 mb-1 uppercase tracking-widest">Email</span>
                        <a href="mailto:dispatch@sk1express.uk" class="text-white hover:text-brand-accent transition-colors">dispatch@sk1express.uk</a>
                    </li>
                    <li>
                        <span class="block text-xs text-slate-500 mb-1 uppercase tracking-widest">HQ</span>
                        <span class="text-white">Birmingham, West Midlands</span>
                    </li>
                </ul>
            </div>
        </div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center border-t border-slate-800 pt-8 text-xs text-slate-500 font-medium">
