                <div class="flex items-center gap-2 text-white font-bold text-sm">
                    <span class="w-2 h-2 bg-brand-accent rounded-full"></span> 24/7 Operations Active
                </div>
            </div>

            <!-- Links Column -->
            <div class="md:col-span-4 lg:col-span-3 lg:col-start-6">
                <h4 class="text-white font-bold uppercase tracking-wider mb-6 text-sm">Logistics Links</h4>
                <ul class="space-y-3 text-sm font-medium">
