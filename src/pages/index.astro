---
// SK1 Express Ltd | B2B Logistics Landing Page
// Original architecture, fully responsive, Birmingham-centric.
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SK1 Express | Dedicated Same Day Couriers Birmingham</title>
    <meta name="description" content="Birmingham's premier dedicated same day courier service. Direct B2B logistics, zero transhipments, and nationwide delivery.">
    
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            dark: '#0f172a', // Slate 900
                            light: '#f8fafc', // Slate 50
                            accent: '#ea580c', // Orange 600
                            accentHover: '#c2410c' // Orange 700
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        html { scroll-behavior: smooth; }
        /* Custom scrollbar for a premium feel */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0f172a; }
        ::-webkit-scrollbar-thumb { background: #ea580c; }
        
        /* Native Accordion Styling */
        details > summary { list-style: none; }
        details > summary::-webkit-details-marker { display: none; }
    </style>
</head>
<body class="bg-brand-light text-slate-800 antialiased selection:bg-brand-accent selection:text-white">

    <!-- Mobile-Optimized Header -->
    <header class="fixed w-full bg-brand-dark/95 backdrop-blur-md border-b border-slate-800 z-50 transition-all">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <!-- Logo -->
                <a href="/" class="text-2xl md:text-3xl font-black text-white tracking-tighter uppercase">
                    SK1<span class="text-brand-accent">Express</span>
                </a>

                <!-- Desktop Nav -->
                <nav class="hidden md:flex gap-8 text-sm font-bold text-slate-300 uppercase tracking-wide">
                    <a href="#solutions" class="hover:text-white transition-colors">Solutions</a>
                    <a href="#industries" class="hover:text-white transition-colors">Industries</a>
                    <a href="#fleet" class="hover:text-white transition-colors">Fleet Specs</a>
                    <a href="#faq" class="hover:text-white transition-colors">FAQ</a>
                </nav>

                <!-- CTA & Mobile Toggle -->
                <div class="flex items-center gap-4">
                    <a href="#quote" class="hidden sm:inline-flex bg-brand-accent hover:bg-brand-accentHover text-white px-6 py-2.5 rounded-sm font-bold uppercase text-sm tracking-wider transition-colors">
                        Urgent Quote
                    </a>
                    <button id="mobile-menu-btn" class="md:hidden text-white p-2">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Mobile Dropdown -->
        <div id="mobile-menu" class="hidden md:hidden bg-brand-dark border-t border-slate-800">
            <div class="px-4 pt-2 pb-6 space-y-2 flex flex-col font-bold text-slate-300 uppercase tracking-wide">
                <a href="#solutions" class="block py-3 border-b border-slate-800">Solutions</a>
                <a href="#industries" class="block py-3 border-b border-slate-800">Industries</a>
                <a href="#fleet" class="block py-3 border-b border-slate-800">Fleet Specs</a>
                <a href="#quote" class="block py-3 text-brand-accent">Get a Quote</a>
            </div>
        </div>
    </header>

    <main>
        <!-- Full Bleed Hero Section with Auto-Adjusting Background -->
        <section class="relative min-h-[90vh] flex items-center pt-20">
            <!-- Fluid Image Placeholder -->
            <div class="absolute inset-0 z-0">
                <img src="https://images.unsplash.com/photo-1580674285054-bed31e145f59?q=80&w=2070&auto=format&fit=crop" alt="Birmingham Logistics Hub" class="w-full h-full object-cover object-center" />
                <div class="absolute inset-0 bg-brand-dark/80 mix-blend-multiply"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/80 to-transparent"></div>
            </div>

            <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
                <div class="max-w-3xl">
                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-brand-accent/20 border border-brand-accent/50 text-brand-accent font-bold text-xs uppercase tracking-widest mb-6 rounded-sm">
                        <span class="w-2 h-2 bg-brand-accent rounded-full animate-pulse"></span>
                        Birmingham Operations Active
                    </div>
                    <h1 class="text-5xl sm:text-6xl md:text-7xl font-black text-white leading-[1.1] tracking-tight mb-6">
                        Mission-Critical <br />
                        B2B Logistics.
                    </h1>
                    <p class="text-lg sm:text-xl text-slate-300 mb-10 font-medium leading-relaxed max-w-2xl">
                        When standard couriers fail, we deliver. Operating out of the West Midlands, providing dedicated, zero-transhipment transport directly to your destination. 
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="#quote" class="bg-brand-accent hover:bg-brand-accentHover text-white px-8 py-4 text-center font-bold uppercase tracking-wider text-lg rounded-sm transition-all shadow-lg">
                            Initiate Transport
                        </a>
                        <a href="tel:+441210000000" class="bg-white/10 hover:bg-white/20 text-white border border-white/20 px-8 py-4 text-center font-bold uppercase tracking-wider text-lg rounded-sm transition-all backdrop-blur-sm">
                            Call 0121 000 0000
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Floating Data Bar -->
        <section class="relative z-20 -mt-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="bg-white border border-slate-200 shadow-2xl rounded-sm p-8 flex flex-col md:flex-row justify-between items-center gap-8 divide-y md:divide-y-0 md:divide-x divide-slate-200">
                <div class="w-full text-center md:px-4">
                    <div class="text-4xl font-black text-brand-dark mb-1">60<span class="text-brand-accent">m</span></div>
                    <div class="text-sm font-bold text-slate-500 uppercase tracking-wide">Target Collection</div>
                </div>
                <div class="w-full text-center md:px-4 pt-8 md:pt-0">
                    <div class="text-4xl font-black text-brand-dark mb-1">24<span class="text-brand-accent">/7</span></div>
                    <div class="text-sm font-bold text-slate-500 uppercase tracking-wide">Dispatch Operations</div>
                </div>
                <div class="w-full text-center md:px-4 pt-8 md:pt-0">
                    <div class="text-4xl font-black text-brand-dark mb-1">£50<span class="text-brand-accent">k</span></div>
                    <div class="text-sm font-bold text-slate-500 uppercase tracking-wide">Transit Insurance</div>
                </div>
            </div>
        </section>

        <!-- Core Solutions (Staggered Layout) -->
        <section id="solutions" class="py-24 overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="mb-16 md:mb-24">
                    <h2 class="text-3xl md:text-5xl font-black text-brand-dark tracking-tight">The Dedicated Difference.</h2>
                    <div class="w-20 h-2 bg-brand-accent mt-6"></div>
                </div>

                <!-- Feature 1 -->
                <div class="grid md:grid-cols-2 gap-12 items-center mb-24">
                    <div class="order-2 md:order-1">
                        <span class="text-brand-accent font-bold tracking-widest uppercase text-sm mb-2 block">Direct Transport</span>
                        <h3 class="text-3xl font-bold text-brand-dark mb-4">Zero Transhipments. Zero Risk.</h3>
                        <p class="text-slate-600 leading-relaxed text-lg mb-6">Standard networks push your cargo through automated hubs, swapping vehicles and increasing the risk of loss or damage. We eliminate the network. Your freight is loaded onto a dedicated vehicle in Birmingham and driven directly to the receiver.</p>
                        <ul class="space-y-3 font-medium text-brand-dark">
                            <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-width="3" d="M5 13l4 4L19 7"></path></svg> Exclusive use of the vehicle</li>
                            <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-width="3" d="M5 13l4 4L19 7"></path></svg> No co-loading with other freight</li>
                            <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-width="3" d="M5 13l4 4L19 7"></path></svg> Direct point-to-point routing</li>
                        </ul>
                    </div>
                    <!-- Auto-Adjusting Aspect Ratio Placeholder -->
                    <div class="order-1 md:order-2 aspect-video md:aspect-square lg:aspect-video w-full overflow-hidden rounded-sm bg-slate-200">
                        <img src="https://images.unsplash.com/photo-1616431169559-b1d556536094?q=80&w=2070&auto=format&fit=crop" alt="Direct Transport Loading" class="w-full h-full object-cover" />
                    </div>
                </div>

                <!-- Feature 2 -->
                <div class="grid md:grid-cols-2 gap-12 items-center">
                    <!-- Auto-Adjusting Aspect Ratio Placeholder -->
                    <div class="aspect-video md:aspect-square lg:aspect-video w-full overflow-hidden rounded-sm bg-slate-200">
                        <img src="https://images.unsplash.com/photo-1551281434-2e90c7ce3ea3?q=80&w=2070&auto=format&fit=crop" alt="Logistics Monitoring" class="w-full h-full object-cover" />
                    </div>
                    <div>
                        <span class="text-brand-accent font-bold tracking-widest uppercase text-sm mb-2 block">Absolute Visibility</span>
                        <h3 class="text-3xl font-bold text-brand-dark mb-4">Unbroken Chain of Custody.</h3>
                        <p class="text-slate-600 leading-relaxed text-lg mb-6">For aerospace, medical, and legal sectors, accountability is non-negotiable. Our operations team tracks your dedicated driver via live GPS telemetry from the moment of dispatch until the digital proof of delivery is signed.</p>
                        <ul class="space-y-3 font-medium text-brand-dark">
                            <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-width="3" d="M5 13l4 4L19 7"></path></svg> Live location updates</li>
                            <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-width="3" d="M5 13l4 4L19 7"></path></svg> Instant electronic POD (ePOD)</li>
                            <li class="flex items-center gap-3"><svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-width="3" d="M5 13l4 4L19 7"></path></svg> Single-driver accountability</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Industrial Sectors (Masonry/Grid Layout) -->
        <section id="industries" class="py-24 bg-brand-dark text-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                    <div class="max-w-2xl">
                        <h2 class="text-3xl md:text-5xl font-black tracking-tight mb-4">Sectors We Power.</h2>
                        <p class="text-slate-400 text-lg">We provide mission-critical logistics pipelines for heavy industry, high-tech manufacturing, and professional services across the UK.</p>
                    </div>
                </div>

                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    <!-- Industry 1 -->
                    <div class="group relative bg-slate-900 border border-slate-800 rounded-sm overflow-hidden hover:border-brand-accent transition-colors">
                        <div class="aspect-[4/3] w-full overflow-hidden bg-slate-800">
                            <img src="https://images.unsplash.com/photo-1565514020179-026b92b84bb6?q=80&w=2070&auto=format&fit=crop" alt="Automotive" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold mb-2">Automotive & Plant</h3>
                            <p class="text-slate-400 text-sm">Line-stopping component delivery. Rapid response to prevent costly manufacturing downtime.</p>
                        </div>
                    </div>
                    <!-- Industry 2 -->
                    <div class="group relative bg-slate-900 border border-slate-800 rounded-sm overflow-hidden hover:border-brand-accent transition-colors">
                        <div class="aspect-[4/3] w-full overflow-hidden bg-slate-800">
                            <img src="https://images.unsplash.com/photo-1574169208507-84376144848b?q=80&w=2079&auto=format&fit=crop" alt="Aerospace" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold mb-2">Aviation & Aerospace</h3>
                            <p class="text-slate-400 text-sm">AOG (Aircraft on Ground) capable logistics. High-security transport for sensitive parts.</p>
                        </div>
                    </div>
                    <!-- Industry 3 -->
                    <div class="group relative bg-slate-900 border border-slate-800 rounded-sm overflow-hidden hover:border-brand-accent transition-colors">
                        <div class="aspect-[4/3] w-full overflow-hidden bg-slate-800">
                            <img src="https://images.unsplash.com/photo-1587370560942-ad2a04eabb6d?q=80&w=2070&auto=format&fit=crop" alt="Medical" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold mb-2">Medical & Pharma</h3>
                            <p class="text-slate-400 text-sm">Time-critical movement of laboratory samples, pharmaceutical supplies, and medical devices.</p>
                        </div>
                    </div>
                    <!-- Industry 4 -->
                    <div class="group relative bg-slate-900 border border-slate-800 rounded-sm overflow-hidden hover:border-brand-accent transition-colors">
                        <div class="aspect-[4/3] w-full overflow-hidden bg-slate-800">
                            <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2069&auto=format&fit=crop" alt="Corporate" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold mb-2">Legal & Financial</h3>
                            <p class="text-slate-400 text-sm">Secure wait-and-return services for highly confidential tender documents and contracts.</p>
                        </div>
                    </div>
                    <!-- Industry 5 -->
                    <div class="group relative bg-slate-900 border border-slate-800 rounded-sm overflow-hidden hover:border-brand-accent transition-colors">
                        <div class="aspect-[4/3] w-full overflow-hidden bg-slate-800">
                            <img src="https://images.unsplash.com/photo-1540317580384-e5d43616b9aa?q=80&w=2070&auto=format&fit=crop" alt="Events" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold mb-2">Events & Broadcast</h3>
                            <p class="text-slate-400 text-sm">Scheduled, hard-deadline deliveries for stage rigging, AV equipment, and exhibition stands.</p>
                        </div>
                    </div>
                    <!-- Industry 6 -->
                    <div class="group relative bg-slate-900 border border-slate-800 rounded-sm overflow-hidden hover:border-brand-accent transition-colors">
                        <div class="aspect-[4/3] w-full overflow-hidden bg-slate-800">
                            <img src="https://images.unsplash.com/photo-1553413077-190dd305871c?q=80&w=2070&auto=format&fit=crop" alt="IT Infrastructure" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold mb-2">IT & Telecoms</h3>
                            <p class="text-slate-400 text-sm">Careful handling and direct transport of fragile server racks and communication infrastructure.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Fleet Grid -->
        <section id="fleet" class="py-24 bg-slate-100">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-5xl font-black text-brand-dark tracking-tight mb-4">Fleet Capabilities.</h2>
                    <p class="text-slate-600 max-w-2xl mx-auto text-lg">From single envelopes to multi-pallet industrial loads, we deploy the exact vehicle your consignment requires.</p>
                </div>
                
                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
                    <!-- Van Type -->
                    <div class="bg-white p-8 border-t-4 border-slate-800 shadow-lg">
                        <h3 class="text-xl font-black text-brand-dark mb-4">Small Courier Van</h3>
                        <ul class="space-y-3 text-sm text-slate-600 mb-6 font-medium">
                            <li class="flex justify-between border-b border-slate-100 pb-2"><span>Max Payload</span> <strong class="text-brand-dark">400 kg</strong></li>
                            <li class="flex justify-between border-b border-slate-100 pb-2"><span>Capacity</span> <strong class="text-brand-dark">1 Pallet</strong></li>
                            <li class="flex justify-between pb-2"><span>Internal L</span> <strong class="text-brand-dark">1.5 meters</strong></li>
                        </ul>
                        <p class="text-xs text-slate-500">Rapid urban deployment. Ideal for secure documents and loose cartons.</p>
                    </div>
                    <!-- Van Type -->
                    <div class="bg-white p-8 border-t-4 border-slate-800 shadow-lg">
                        <h3 class="text-xl font-black text-brand-dark mb-4">Medium Van (SWB)</h3>
                        <ul class="space-y-3 text-sm text-slate-600 mb-6 font-medium">
                            <li class="flex justify-between border-b border-slate-100 pb-2"><span>Max Payload</span> <strong class="text-brand-dark">900 kg</strong></li>
                            <li class="flex justify-between border-b border-slate-100 pb-2"><span>Capacity</span> <strong class="text-brand-dark">2 Pallets</strong></li>
                            <li class="flex justify-between pb-2"><span>Internal L</span> <strong class="text-brand-dark">2.4 meters</strong></li>
                        </ul>
                        <p class="text-xs text-slate-500">The industry standard. Perfect for standard B2B freight and components.</p>
                    </div>
                    <!-- Van Type -->
                    <div class="bg-white p-8 border-t-4 border-slate-800 shadow-lg">
                        <h3 class="text-xl font-black text-brand-dark mb-4">Large Van (LWB)</h3>
                        <ul class="space-y-3 text-sm text-slate-600 mb-6 font-medium">
                            <li class="flex justify-between border-b border-slate-100 pb-2"><span>Max Payload</span> <strong class="text-brand-dark">1,200 kg</strong></li>
                            <li class="flex justify-between border-b border-slate-100 pb-2"><span>Capacity</span> <strong class="text-brand-dark">3-4 Pallets</strong></li>
                            <li class="flex justify-between pb-2"><span>Internal L</span> <strong class="text-brand-dark">3.3 meters</strong></li>
                        </ul>
                        <p class="text-xs text-slate-500">High volume transport for oversized lengths and bulk distribution.</p>
                    </div>
                    <!-- Van Type -->
                    <div class="bg-white p-8 border-t-4 border-brand-accent shadow-lg relative overflow-hidden">
                        <div class="absolute top-0 right-0 bg-brand-accent text-white text-[10px] font-bold uppercase tracking-wider py-1 px-3">Heavy Lift</div>
                        <h3 class="text-xl font-black text-brand-dark mb-4">Luton Tail-Lift</h3>
                        <ul class="space-y-3 text-sm text-slate-600 mb-6 font-medium">
                            <li class="flex justify-between border-b border-slate-100 pb-2"><span>Max Payload</span> <strong class="text-brand-dark">1,000 kg</strong></li>
                            <li class="flex justify-between border-b border-slate-100 pb-2"><span>Capacity</span> <strong class="text-brand-dark">6 Pallets</strong></li>
                            <li class="flex justify-between pb-2"><span>Internal L</span> <strong class="text-brand-dark">4.0 meters</strong></li>
                        </ul>
                        <p class="text-xs text-slate-500">Equipped with mechanical tail-lift. Essential for heavy machinery.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Birmingham & Coverage / FAQ Split -->
        <section id="faq" class="py-24 bg-white border-b border-slate-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid lg:grid-cols-2 gap-16">
                    
                    <!-- Left: Coverage & Map -->
                    <div>
                        <h2 class="text-3xl font-black text-brand-dark mb-6">Midlands Based.<br/>Nationwide Reach.</h2>
                        <p class="text-slate-600 mb-8 leading-relaxed">Strategically headquartered in Birmingham, we have immediate access to the M6, M5, and M42 corridors. This allows us to dispatch vehicles rapidly across the West Midlands and deliver anywhere in the UK mainland on the exact same day.</p>
                        
                        <!-- Auto-Adjusting Map Placeholder -->
                        <div class="aspect-video w-full rounded-sm overflow-hidden bg-slate-200 border border-slate-300 shadow-md">
                            <iframe 
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d155355.84594639906!2d-2.0298717833076135!3d52.49692482315802!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4870942d1b417173%3A0xca81fef0aeee7998!2sBirmingham!5e0!3m2!1sen!2suk!4v1700000000000!5m2!1sen!2suk" 
                                width="100%" 
                                height="100%" 
                                style="border:0;" 
                                allowfullscreen="" 
                                loading="lazy" 
                                referrerpolicy="no-referrer-when-downgrade">
                            </iframe>
                        </div>
                    </div>

                    <!-- Right: Native HTML FAQ Accordion -->
                    <div>
                        <h2 class="text-3xl font-black text-brand-dark mb-8">Operational FAQs</h2>
                        <div class="space-y-4">
                            <details class="group bg-slate-50 border border-slate-200 rounded-sm p-6 open:bg-white open:shadow-md transition-all cursor-pointer" open>
                                <summary class="font-bold text-brand-dark flex justify-between items-center text-lg">
                                    How fast can you collect my freight?
                                    <svg class="w-5 h-5 text-brand-accent group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </summary>
                                <p class="text-slate-600 mt-4 leading-relaxed font-medium">In the West Midlands and major UK cities, our target collection time is within 60 minutes of booking confirmation. Regional collections vary slightly but are always expedited.</p>
                            </details>

                            <details class="group bg-slate-50 border border-slate-200 rounded-sm p-6 open:bg-white open:shadow-md transition-all cursor-pointer">
                                <summary class="font-bold text-brand-dark flex justify-between items-center text-lg">
                                    Are my goods insured in transit?
                                    <svg class="w-5 h-5 text-brand-accent group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </summary>
                                <p class="text-slate-600 mt-4 leading-relaxed font-medium">Yes. Every dedicated delivery is covered by our standard Goods in Transit (GIT) insurance up to £50,000. Extended cover can be arranged for high-value assets.</p>
                            </details>

                            <details class="group bg-slate-50 border border-slate-200 rounded-sm p-6 open:bg-white open:shadow-md transition-all cursor-pointer">
                                <summary class="font-bold text-brand-dark flex justify-between items-center text-lg">
                                    Do you operate outside normal business hours?
                                    <svg class="w-5 h-5 text-brand-accent group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </summary>
                                <p class="text-slate-600 mt-4 leading-relaxed font-medium">Logistics does not sleep. Our dispatch team and driver network operate 24 hours a day, 7 days a week, 365 days a year.</p>
                            </details>
                            
                            <details class="group bg-slate-50 border border-slate-200 rounded-sm p-6 open:bg-white open:shadow-md transition-all cursor-pointer">
                                <summary class="font-bold text-brand-dark flex justify-between items-center text-lg">
                                    Will my goods be mixed with other deliveries?
                                    <svg class="w-5 h-5 text-brand-accent group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </summary>
                                <p class="text-slate-600 mt-4 leading-relaxed font-medium">Absolutely not. We operate a strict dedicated vehicle policy. Once your freight is loaded, the vehicle drives straight to your receiver with zero co-loading.</p>
                            </details>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- Quote Form Section (Preserved API Integration) -->
        <section id="quote" class="py-24 bg-brand-light relative">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="bg-brand-dark rounded-sm shadow-2xl p-6 sm:p-10 md:p-14 border-t-8 border-brand-accent relative overflow-hidden">
                    
                    <!-- Decorative Background element -->
                    <div class="absolute -top-24 -right-24 w-64 h-64 bg-brand-accent opacity-10 rounded-full blur-3xl"></div>

                    <div class="relative z-10">
                        <div class="mb-10">
                            <h2 class="text-3xl md:text-4xl font-black text-white mb-3">Initiate Urgent Transit.</h2>
                            <p class="text-slate-400 text-lg">Enter your consignment details below for an immediate pricing structure and vehicle allocation.</p>
                        </div>

                        <form class="space-y-6" id="quoteForm">
                            <!-- Anti-Spam Honeypot (Preserved) -->
                            <div style="position: absolute; left: -5000px;" aria-hidden="true">
                                <input type="text" id="sk1_bot_trap" tabindex="-1" value="" autocomplete="off" />
                            </div>

                            <div class="grid md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Collection Postcode</label>
                                    <input type="text" id="collection" class="w-full bg-slate-900 border border-slate-700 text-white p-4 rounded-sm font-bold focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition" placeholder="e.g. B1 1AA" required maxlength="8" />
                                    <p id="col-error" class="text-red-500 text-xs mt-2 hidden font-bold">Invalid UK Postcode format.</p>
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Delivery Postcode</label>
                                    <input type="text" id="delivery" class="w-full bg-slate-900 border border-slate-700 text-white p-4 rounded-sm font-bold focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition" placeholder="e.g. EC1A 1BB" required maxlength="8" />
                                    <p id="del-error" class="text-red-500 text-xs mt-2 hidden font-bold">Invalid UK Postcode format.</p>
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Consignment Details (Weight / Dims)</label>
                                <textarea id="cargo" class="w-full bg-slate-900 border border-slate-700 text-white p-4 rounded-sm font-medium focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition h-28" placeholder="e.g. 1 x Standard Pallet, 450kg total. Automotive parts." required></textarea>
                            </div>
                            <button type="submit" id="submitBtn" class="w-full bg-brand-accent hover:bg-brand-accentHover text-white font-black text-lg py-5 rounded-sm transition-all shadow-[0_0_15px_rgba(234,88,12,0.4)] flex justify-center items-center gap-2 uppercase tracking-wide">
                                Submit Request to Dispatch
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </section>

        <!-- Javascript Logic: API & Mobile Menu -->
        <script is:inline>
            // --- Mobile Menu Toggle ---
            const btn = document.getElementById('mobile-menu-btn');
            const menu = document.getElementById('mobile-menu');
            btn.addEventListener('click', () => {
                menu.classList.toggle('hidden');
            });
            // Close menu on link click
            menu.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => menu.classList.add('hidden'));
            });

            // --- Form Validation & API Request (Preserved) ---
            const formatPostcode = (val) => {
                let v = val.toUpperCase().replace(/[^A-Z0-9]/g, '');
                if (v.length > 4) v = v.slice(0, -3) + ' ' + v.slice(-3);
                return v;
            };

            const isValidPostcode = (p) => /^[A-Z]{1,2}[0-9][A-Z0-9]? ?[0-9][A-Z]{2}$/i.test(p);

            ['collection', 'delivery'].forEach(id => {
                document.getElementById(id).addEventListener('input', (e) => {
                    e.target.value = formatPostcode(e.target.value);
                    document.getElementById(`${id.substring(0,3)}-error`).classList.add('hidden');
                });
            });

            document.getElementById('quoteForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const col = document.getElementById('collection').value;
                const del = document.getElementById('delivery').value;
                let hasError = false;

                if (!isValidPostcode(col)) { document.getElementById('col-error').classList.remove('hidden'); hasError = true; }
                if (!isValidPostcode(del)) { document.getElementById('del-error').classList.remove('hidden'); hasError = true; }
                if (hasError) return;

                const submitBtn = document.getElementById('submitBtn');
                submitBtn.disabled = true;
                submitBtn.innerText = 'Transmitting Data...';

                const payload = {
                    collection: col,
                    delivery: del,
                    cargo: document.getElementById('cargo').value,
                    trap: document.getElementById('sk1_bot_trap').value
                };

                try {
                    const response = await fetch('https://api.sk1express.uk', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        alert('Logistics request received. Dispatch will contact you immediately.');
                        document.getElementById('quoteForm').reset();
                    } else {
                        alert('API routing error. Please call dispatch directly on 0121 000 0000.');
                    }
                } catch (err) {
                    alert('Network error. Please call dispatch directly on 0121 000 0000.');
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.innerText = 'Submit Request to Dispatch';
                }
            });
        </script>
    </main>

